{
  "name": "lucassayeg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "vercel-build": "payload migrate && next build",
    "start": "next start",
    "payload": "payload",
    "generate:importmap": "payload generate:importmap",
    "generate:types": "payload generate:types",
    "lint": "oxlint --ignore-pattern=src/app/blog/** --ignore-pattern=src/app/feed.xml/** --ignore-pattern=src/app/actions/blog.ts --ignore-pattern=src/ui/blog/components/** src/",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "typecheck": "tsgo --noEmit",
    "arch:check": "bash scripts/arch-check.sh",
    "db:branch": "tsx scripts/db-branch.ts",
    "db:reset": "tsx scripts/db-reset.ts",
    "db:migrate": "payload migrate",
    "db:migrate:create": "payload migrate:create",
    "db:migrate:status": "payload migrate:status",
    "seed": "tsx --require ./src/seed/shim.cjs --env-file .env.local src/seed/index.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@payloadcms/db-vercel-postgres": "3.78.0",
    "@payloadcms/next": "3.78.0",
    "@payloadcms/richtext-lexical": "3.78.0",
    "@payloadcms/storage-vercel-blob": "3.78.0",
    "@payloadcms/translations": "3.78.0",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16.13.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "payload": "3.78.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "resend": "^6.9.3",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript/native-preview": "7.0.0-dev.20260227.1",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.33.2"
}
